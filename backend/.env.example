# Backend API — copy to backend/.env
# NEVER commit this file with real keys

PORT=3001

# AI provider: ollama-local | mock | openai | gemini
AI_PROVIDER=ollama-local

# Ollama (local) — used when AI_PROVIDER=ollama-local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI — placeholder for later (used when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini — placeholder for later (used when AI_PROVIDER=gemini)
GEMINI_API_KEY=

# Optional: spoken audio transcription (Facebook reels, YouTube caption fallback)
# Facebook attempts audio transcription by default unless set to false
AUDIO_TRANSCRIPTION_ENABLED=true

# Transcription provider: auto | openai | whisper-api
TRANSCRIPTION_PROVIDER=whisper-api

# Local Whisper — run: powershell -File backend/scripts/start-whisper.ps1
WHISPER_API_URL=http://localhost:8000/v1
WHISPER_MODEL=whisper-1

# Extra yt-dlp args (e.g. --cookies-from-browser chrome for private Facebook)
# YT_DLP_EXTRA_ARGS=
