{
  "name": "recipe-extractor",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 8081 --host lan",
    "preview": "powershell -ExecutionPolicy Bypass -File scripts/preview-web.ps1",
    "web": "powershell -ExecutionPolicy Bypass -File scripts/preview-web.ps1",
    "android": "powershell -ExecutionPolicy Bypass -File scripts/run-android.ps1",
    "android:adb": "powershell -ExecutionPolicy Bypass -File scripts/setup-adb-reverse.ps1",
    "connect:phone": "powershell -ExecutionPolicy Bypass -File scripts/connect-phone.ps1",
    "android:standalone": "powershell -ExecutionPolicy Bypass -File scripts/build-standalone.ps1",
    "dev:setup": "powershell -ExecutionPolicy Bypass -File scripts/dev-setup.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "expo": "~52.0.46",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "~0.13.3",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.20",
    "expo-splash-screen": "~0.29.22",
    "expo-status-bar": "~2.0.1",
    "nativewind": "4.0.36",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-reanimated": "~3.16.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~18.3.18",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.3.3"
  },
  "private": true
}
