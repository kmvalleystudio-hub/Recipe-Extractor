# Mobile app — copy to .env in project root
#
# Backend API URL (no API keys here — Ollama runs on the backend only)
#
# LOCAL DEVELOPMENT:
# - Physical Android phone or emulator cannot use "localhost" — that refers to the device.
# - Use your computer's LAN IP instead, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:3001
# - Find your IP on Windows: run "ipconfig" and look for IPv4 Address.
# - The backend on your PC then calls Ollama at http://localhost:11434.
#
EXPO_PUBLIC_API_URL=http://localhost:3001
